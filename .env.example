# Copy this file to .env and fill in all CHANGE_ME values before running

# PostgreSQL
DB_URL=jdbc:postgresql://postgres:5432/mediadb
DB_USER=CHANGE_ME
DB_PASS=CHANGE_ME

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_QUEUE=download:jobs

# MinIO
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=downloads
SIGNED_URL_EXPIRY_HOURS=24

# App
ALLOWED_DOMAINS=youtube.com,youtu.be,www.youtube.com
RATE_LIMIT_RPM=10
